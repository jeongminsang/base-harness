{
  "version": "0.1",
  "preset": "vite",
  "adapters": "all",
  "buildCheckCmd": "./node_modules/.bin/tsc -b",
  "lintCmd": "npx eslint",
  "srcDir": "src/",
  "archTriggerPaths": [
    "src/pages/",
    "src/components/"
  ],
  "qaTriggerMinLines": 50,
  "qualityGate": {
    "minDiffLines": 10,
    "rejectWhitespaceOnly": true,
    "rejectIfDuplicateSkill": true
  }
}
